#!/bin/bash

set -euo pipefail

LOCAL_DIR=$(git rev-parse --show-toplevel)
cd "${LOCAL_DIR}"

# update-venv references VIRTUAL_ENV directly; ensure it is always defined.
VIRTUAL_ENV="${VIRTUAL_ENV:-}"
source "${LOCAL_DIR}/.githooks/update-venv"

mapfile -t STAGED_PY_FILES < <(
    git diff --cached --name-only --diff-filter=ACMR | awk '/\.py$/ {print}'
)

if [[ ${#STAGED_PY_FILES[@]} -eq 0 ]]; then
    echo "No staged Python files. Skipping Python pre-commit checks."
    exit 0
fi

echo "Static type checking (ty) on staged Python files..."
ty check --no-progress --force-exclude "${STAGED_PY_FILES[@]}"
echo "Linting (ruff) on staged Python files..."
ruff check --force-exclude "${STAGED_PY_FILES[@]}"
echo "Formatting (ruff) on staged Python files..."
ruff format --force-exclude "${STAGED_PY_FILES[@]}"

# Keep staged content aligned when formatting rewrites files.
git add "${STAGED_PY_FILES[@]}"
